<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

        <import type="android.view.View" />

        <variable
            name="activity"
            type="com.kyad.traystorage.app.setting.VersionActivity" />

        <variable
            name="model"
            type="com.kyad.traystorage.app.setting.VersionActivity.ViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="4dp">

            <ImageView
                android:id="@+id/ib_close"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_centerVertical="true"
                android:background="@color/transparent"
                android:foreground="?attr/selectableItemBackground"
                android:onClick="@{()->activity.onBackPressed()}"
                android:padding="12dp"
                android:src="@drawable/ic_back" />

            <com.kyad.traystorage.app.common.font.FontTextView
                style="@style/font_spoqahansansneo_bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:includeFontPadding="false"
                android:text="@string/version_information"
                android:textColor="@color/C151515"
                android:textSize="18sp" />

        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- 업데이트 필요 시 상단 문구 -->
            <com.kyad.traystorage.app.common.font.FontTextView
                style="@style/font_spoqahansansneo_regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:lineHeight="34dp"
                android:text="@string/version_information1"
                android:textColor="#111111"
                android:textSize="22sp"
                android:visibility="@{model.isUpdate?View.VISIBLE:View.GONE}" />

            <!-- 최신 버전일 때 상단 문구 -->
            <com.kyad.traystorage.app.common.font.FontTextView
                style="@style/font_spoqahansansneo_regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:lineHeight="34dp"
                android:text="@string/version_information2"
                android:textColor="#111111"
                android:textSize="22sp"
                android:visibility="@{model.isUpdate?View.GONE:View.VISIBLE}" />

            <!-- 로고 이미지 -->
            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="40dp"
                android:scaleType="fitCenter"
                android:src="@drawable/version_logo" />

            <!-- 버전 정보 영역 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <!-- 현재 버전 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.kyad.traystorage.app.common.font.FontTextView
                        style="@style/font_spoqahansansneo_regular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="@string/current_version"
                        android:textColor="#111111"
                        android:textSize="15sp" />

                    <com.kyad.traystorage.app.common.font.FontTextView
                        android:id="@+id/label_currentversion"
                        style="@style/font_spoqahansansneo_bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:includeFontPadding="false"
                        android:text="@{model.oldVersion}"
                        android:textColor="#111111"
                        android:textSize="15sp" />
                </LinearLayout>

                <!-- 최신 버전 (업데이트 필요 시에만 표시) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:visibility="@{model.isUpdate?View.VISIBLE:View.GONE}">

                    <com.kyad.traystorage.app.common.font.FontTextView
                        style="@style/font_spoqahansansneo_regular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="@string/newest_version"
                        android:textColor="@color/focus_color"
                        android:textSize="15sp" />

                    <com.kyad.traystorage.app.common.font.FontTextView
                        android:id="@+id/label_newestversion"
                        style="@style/font_spoqahansansneo_bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:includeFontPadding="false"
                        android:text="@{model.newVersion}"
                        android:textColor="@color/focus_color"
                        android:textSize="15sp" />
                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.kyad.traystorage.app.common.font.FontButton
                android:id="@+id/next_btn"
                style="@style/font_spoqahansansneo_bold"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_btn_approve_both"
                android:enabled="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:onClick="@{()->activity.onConfirm()}"
                android:text="@string/update_version_button"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:visibility="@{model.isUpdate?View.VISIBLE:View.GONE}" />
        </LinearLayout>
    </LinearLayout>

</layout>