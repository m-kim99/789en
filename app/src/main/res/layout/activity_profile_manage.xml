<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />

        <variable
            name="activity"
            type="com.us.traystorage.app.setting.ProfileManageActivity" />

        <variable
            name="model"
            type="com.us.traystorage.app.setting.ProfileManageActivity.ViewModel" />
    </data>

    <LinearLayout
        android:id="@+id/bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:orientation="vertical">

        <!-- ?�더 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="4dp">

            <ImageView
                android:id="@+id/ib_close"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_centerVertical="true"
                android:background="@color/transparent"
                android:foreground="?attr/selectableItemBackground"
                android:onClick="@{()->activity.onBackPressed()}"
                android:padding="12dp"
                android:src="@drawable/ic_back" />

            <com.us.traystorage.app.common.font.FontTextView
                style="@style/font_spoqahansansneo_bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/profile_management"
                android:textColor="@color/C151515"
                android:textSize="18sp"
                android:includeFontPadding="false" />

            <!-- ?�정 버튼 (?�상?? -->
            <com.us.traystorage.app.common.font.FontTextView
                android:id="@+id/btn_edit"
                style="@style/font_spoqahansansneo_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:onClick="@{()->activity.onClickEdit()}"
                android:text="Edit"
                android:textColor="#1E319D"
                android:textSize="16sp"
                android:includeFontPadding="false"
                android:visibility="@{activity.isEditable?View.GONE:View.VISIBLE}" />

            <!-- ?�료 버튼 (?�정?? -->
            <com.us.traystorage.app.common.font.FontTextView
                android:id="@+id/btn_complete"
                style="@style/font_spoqahansansneo_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:onClick="@{()->activity.onConfirm()}"
                android:text="Done"
                android:textColor="#1E319D"
                android:textSize="16sp"
                android:includeFontPadding="false"
                android:visibility="@{activity.isEditable?View.VISIBLE:View.GONE}" />

        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="24dp">

                <!-- ?�로???��?지 -->
                <RelativeLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginBottom="16dp">

                    <com.makeramen.roundedimageview.RoundedImageView
                        android:id="@+id/img_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/icon_c_user_60"
                        app:riv_corner_radius="40dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:onClick="@{()->activity.onClickProfile()}"
                        android:src="@drawable/icon_c_add_24"
                        android:visibility="@{activity.isEditable?View.VISIBLE:View.GONE}" />
                </RelativeLayout>

                <!-- ?�름 (?�상?? -->
                <com.us.traystorage.app.common.font.FontTextView
                    android:id="@+id/label_name"
                    style="@style/font_spoqahansansneo_bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginBottom="20dp"
                    android:text="@{model.name}"
                    android:textColor="@color/black"
                    android:textSize="24sp"
                    android:includeFontPadding="false"
                    android:visibility="@{activity.isEditable?View.GONE:View.VISIBLE}" />

                <!-- ?�름 ?�력 (?�정?? -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginBottom="20dp"
                    android:visibility="@{activity.isEditable?View.VISIBLE:View.GONE}">

                    <com.us.traystorage.app.common.font.FontEditText
                        android:id="@+id/edit_name"
                        style="@style/font_spoqahansansneo_bold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toStartOf="@id/clear_btn"
                        android:background="@null"
                        android:includeFontPadding="false"
                        android:maxLength="50"
                        android:paddingVertical="8dp"
                        android:text="@={model.name}"
                        android:textColor="@color/black"
                        android:textSize="24sp" />

                    <ImageView
                        android:id="@+id/clear_btn"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:onClick="@{()->activity.onDeleteName()}"
                        android:src="@drawable/icon_common_24x24_close" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_below="@id/edit_name"
                        android:background="#DDDDDD" />
                </RelativeLayout>

                <!-- 구분??-->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:background="#F5F5F5" />

                <!-- 기본 ?�보 ?�션 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp">

                    <com.us.traystorage.app.common.font.FontTextView
                        style="@style/font_spoqahansansneo_bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Basic Info"
                        android:textColor="@color/C151515"
                        android:textSize="16sp"
                        android:includeFontPadding="false" />

                    <!-- ?�년?�일 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.us.traystorage.app.common.font.FontTextView
                            style="@style/font_spoqahansansneo_regular"
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:text="Date of Birth"
                            android:textColor="#888888"
                            android:textSize="14sp"
                            android:includeFontPadding="false" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:onClick="@{()->activity.onClickBirthDay()}">

                            <com.us.traystorage.app.common.font.FontTextView
                                android:id="@+id/edit_birthday"
                                style="@style/font_spoqahansansneo_regular"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_toStartOf="@id/icon_birthday_dropdown"
                                android:background="@null"
                                android:hint="Select date of birth"
                                android:text="@{model.birthday}"
                                android:textColor="@color/black"
                                android:textColorHint="#AAAAAA"
                                android:textSize="16sp"
                                android:includeFontPadding="false" />

                            <ImageView
                                android:id="@+id/icon_birthday_dropdown"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_arrow_down"
                                android:visibility="@{activity.isEditable?View.VISIBLE:View.GONE}" />
                        </RelativeLayout>
                    </LinearLayout>

                    <!-- ?�메??-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.us.traystorage.app.common.font.FontTextView
                            style="@style/font_spoqahansansneo_regular"
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:text="Email"
                            android:textColor="#888888"
                            android:textSize="14sp"
                            android:includeFontPadding="false" />

                        <com.us.traystorage.app.common.font.FontEditText
                            android:id="@+id/edit_email"
                            style="@style/font_spoqahansansneo_regular"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:enabled="@{activity.isEditable}"
                            android:hint="Enter email"
                            android:includeFontPadding="false"
                            android:inputType="textEmailAddress"
                            android:text="@={model.email}"
                            android:textColor="@color/black"
                            android:textColorHint="#AAAAAA"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- ?�별 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.us.traystorage.app.common.font.FontTextView
                            style="@style/font_spoqahansansneo_regular"
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:text="Gender"
                            android:textColor="#888888"
                            android:textSize="14sp"
                            android:includeFontPadding="false" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.us.traystorage.app.common.font.FontButton
                                android:id="@+id/button_sex1"
                                style="@style/font_spoqahansansneo_medium"
                                android:layout_width="56dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_btn_gender"
                                android:includeFontPadding="false"
                                android:onClick="@{()->activity.onSex1()}"
                                android:text="Male"
                                android:textColor="#1E319D"
                                android:textSize="14sp" />

                            <com.us.traystorage.app.common.font.FontButton
                                android:id="@+id/button_sex2"
                                style="@style/font_spoqahansansneo_medium"
                                android:layout_width="56dp"
                                android:layout_height="36dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_btn_gender"
                                android:includeFontPadding="false"
                                android:onClick="@{()->activity.onSex2()}"
                                android:text="Female"
                                android:textColor="#1E319D"
                                android:textSize="14sp" />

                            <com.us.traystorage.app.common.font.FontButton
                                android:id="@+id/button_sex3"
                                style="@style/font_spoqahansansneo_medium"
                                android:layout_width="56dp"
                                android:layout_height="36dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_btn_gender"
                                android:includeFontPadding="false"
                                android:onClick="@{()->activity.onSex3()}"
                                android:text="Private"
                                android:textColor="#1E319D"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</layout>