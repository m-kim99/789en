<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".app.auth.LoginHomeActivity">

    <data>
        <import type="android.view.View" />
        <variable
            name="activity"
            type="com.us.traystorage.app.auth.LoginHomeActivity" />
    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 배경 ?��?지 -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/login"
            android:scaleType="fitXY" />

        <!-- ?�단: 로고 + 문구 -->
        <LinearLayout
            android:id="@+id/layout_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginTop="84dp"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="24dp">

            <!-- 로고 -->
            <ImageView
                android:layout_width="240dp"
                android:layout_height="48dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/view" />

            <!-- 문구 -->
            <com.us.traystorage.app.common.font.FontTextView
                style="@style/font_notosans_kr_bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Smarter document\norganization and management"
                android:textColor="#111111"
                android:textSize="24sp"
                android:lineHeight="32sp"
                android:gravity="center"
                android:includeFontPadding="false" />
        </LinearLayout>

        <!-- ?�단: 버튼 ?�역 -->
        <LinearLayout
            android:id="@+id/layout_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="24dp"
            android:orientation="vertical"
            android:paddingHorizontal="32dp">

            <!-- ?�스??모드 버튼 (비활?�화: ?�요??주석 ?�제?�여 ?�용)
            <com.us.traystorage.app.common.font.FontButton
                android:id="@+id/btn_test_mode"
                style="@style/font_notosans_kr_bold"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:text="Test Mode"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:background="@drawable/bg_btn_test_mode"
                android:gravity="center"
                android:onClick="@{()->activity.goTestMode()}"
                android:includeFontPadding="false" />
            -->

            <!-- 로그??버튼 -->
            <com.us.traystorage.app.common.font.FontButton
                android:id="@+id/btn_login"
                style="@style/font_notosans_kr_bold"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Sign In"
                android:textColor="#FDFDFE"
                android:textSize="18sp"
                android:background="@drawable/bg_btn_login_primary"
                android:gravity="center"
                android:onClick="@{()->activity.goLogin()}"
                android:includeFontPadding="false" />

            <!-- ?�원가??버튼 -->
            <com.us.traystorage.app.common.font.FontButton
                android:id="@+id/btn_signup"
                style="@style/font_notosans_kr_bold"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="Sign Up"
                android:textColor="#1E319D"
                android:textSize="18sp"
                android:background="@drawable/bg_btn_login_secondary"
                android:gravity="center"
                android:onClick="@{()->activity.goSignUp()}"
                android:includeFontPadding="false" />

            <!-- ?�는 -->
            <com.us.traystorage.app.common.font.FontTextView
                style="@style/font_notosans_kr_regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="12dp"
                android:text="or"
                android:textColor="#111111"
                android:textSize="14sp"
                android:lineHeight="20sp"
                android:gravity="center"
                android:includeFontPadding="false" />

            <!-- SNS Login Icons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingVertical="12dp">

                <!-- Google -->
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/icon_sns_google_60"
                    android:onClick="@{()->activity.goSnsSignup(1)}"
                    android:scaleType="fitCenter" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</layout>