<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- ?�단 ?�목 ?�역 -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        android:orientation="vertical">

        <com.us.traystorage.app.common.font.FontTextView
            style="@style/font_notosans_kr_bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TrayStorage Permission Guide"
            android:textColor="#111111"
            android:textSize="18sp"
            android:includeFontPadding="false" />

        <com.us.traystorage.app.common.font.FontTextView
            style="@style/font_notosans_kr_regular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="TrayStorage uses the following permissions.\nPlease allow permissions for smooth service use."
            android:textColor="#6B6C6E"
            android:textSize="14sp"
            android:lineSpacingExtra="6dp"
            android:includeFontPadding="false" />
    </LinearLayout>

    <!-- 권한 리스???�역 -->
    <ScrollView
        android:id="@+id/permission_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@id/header"
        android:layout_above="@id/footer"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ?�단 구분??-->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EBEDF0" />

            <!-- ?�수 ?�근 권한 ?�목 -->
            <com.us.traystorage.app.common.font.FontTextView
                style="@style/font_notosans_kr_bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Required Access Permissions"
                android:textColor="#1E319D"
                android:textSize="16sp"
                android:includeFontPadding="false" />

            <!-- 권한 박스 1: ?�락�?-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_permission_box">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_permission_call" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <com.us.traystorage.app.common.font.FontTextView
                        style="@style/font_notosans_kr_bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contacts"
                        android:textColor="#111111"
                        android:textSize="14sp"
                        android:includeFontPadding="false" />

                    <com.us.traystorage.app.common.font.FontTextView
                        style="@style/font_notosans_kr_regular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Contact-based friend invitation service"
                        android:textColor="#6B6C6E"
                        android:textSize="14sp"
                        android:includeFontPadding="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- 권한 박스 2: 카메??-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_permission_box">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_permission_camera" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <com.us.traystorage.app.common.font.FontTextView
                        style="@style/font_notosans_kr_bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Camera"
                        android:textColor="#111111"
                        android:textSize="14sp"
                        android:includeFontPadding="false" />

                    <com.us.traystorage.app.common.font.FontTextView
                        style="@style/font_notosans_kr_regular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Document photo capture service"
                        android:textColor="#6B6C6E"
                        android:textSize="14sp"
                        android:includeFontPadding="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- 권한 박스 3: ?�?�공�?-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_permission_box">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_permission_storage" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <com.us.traystorage.app.common.font.FontTextView
                        style="@style/font_notosans_kr_bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Storage"
                        android:textColor="#111111"
                        android:textSize="14sp"
                        android:includeFontPadding="false" />

                    <com.us.traystorage.app.common.font.FontTextView
                        style="@style/font_notosans_kr_regular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Captured photos are saved and document photos\ncan be attached"
                        android:textColor="#6B6C6E"
                        android:textSize="14sp"
                        android:lineSpacingExtra="6dp"
                        android:includeFontPadding="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- ?�단 구분??-->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:background="#EBEDF0" />

            <!-- ?�내 문구 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal"
                android:gravity="start">

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_bullet_dot" />

                <com.us.traystorage.app.common.font.FontTextView
                    style="@style/font_notosans_kr_regular"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="If there is a permission error, you can re-grant\npermissions by deleting and reinstalling the app."
                    android:textColor="#6B6C6E"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ?�단 버튼 ?�역 -->
    <LinearLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EBEDF0" />

        <com.us.traystorage.app.common.font.FontButton
            android:id="@+id/btn_confirm"
            style="@style/font_notosans_kr_bold"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginVertical="12dp"
            android:text="Confirm"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:background="@drawable/bg_btn_confirm_bottom"
            android:gravity="center" />

        <!-- Android Navigation Bar 공간 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/white" />
    </LinearLayout>
</RelativeLayout>
