<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- ?�로가�?& ?�기 버튼 -->
    <RelativeLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="24dp"
            android:src="@drawable/ic_back"
            android:visibility="invisible" />

        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="24dp"
            android:src="@drawable/ic_close" />
    </RelativeLayout>

    <!-- 진행 ?�시 ??-->
    <LinearLayout
        android:id="@+id/indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/top_bar"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_margin="3dp"
            android:background="@drawable/bg_indicator_active" />
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_margin="3dp"
            android:background="@drawable/bg_indicator_inactive" />
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_margin="3dp"
            android:background="@drawable/bg_indicator_inactive" />
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_margin="3dp"
            android:background="@drawable/bg_indicator_inactive" />
    </LinearLayout>

    <!-- ?�목 ?�스??-->
    <com.us.traystorage.app.common.font.FontTextView
        android:id="@+id/text_title"
        style="@style/font_notosans_kr_bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/indicator"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:text="Important documents are hard to find\nwhen you need them?"
        android:textColor="#111111"
        android:textSize="24sp"
        android:lineSpacingExtra="8dp"
        android:gravity="center"
        android:includeFontPadding="false" />

    <!-- ?�러?�트 ?��?지 -->
    <ImageView
        android:id="@+id/img_illustration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/text_title"
        android:layout_marginTop="12dp"
        android:layout_alignParentBottom="true"
        android:adjustViewBounds="true"
        android:scaleType="centerCrop"
        android:src="@drawable/img_intro_onboarding1" />
</RelativeLayout>
